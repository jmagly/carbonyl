From d637b080f024cac5dddc5f195285c9837c3ba98c Mon Sep 17 00:00:00 2001
From: Joseph Magly <1159087+jmagly@users.noreply.github.com>
Date: Sun, 5 Apr 2026 01:32:54 -0400
Subject: [PATCH 3/4] fix(m120): fix Blink font API changes in
 style_resolver.cc

- SetFamily() requires explicit AtomicString, not const char*
- ExtraExpandedWidthValue() renamed to kExtraExpandedWidthValue constant

diff --git a/third_party/blink/renderer/core/css/resolver/style_resolver.cc b/third_party/blink/renderer/core/css/resolver/style_resolver.cc
index 126eb38ee3539..37489cc50dd29 100644
--- a/third_party/blink/renderer/core/css/resolver/style_resolver.cc
+++ b/third_party/blink/renderer/core/css/resolver/style_resolver.cc
@@ -1146,9 +1146,9 @@ const ComputedStyle* StyleResolver::ResolveStyle(
     auto font = state.StyleBuilder().GetFontDescription();
     FontFamily family;
 
-    family.SetFamily("monospace", FontFamily::Type::kGenericFamily);
+    family.SetFamily(AtomicString("monospace"), FontFamily::Type::kGenericFamily);
     font.SetFamily(family);
-    font.SetStretch(ExtraExpandedWidthValue());
+    font.SetStretch(kExtraExpandedWidthValue);
     font.SetKerning(FontDescription::kNoneKerning);
     font.SetComputedSize(13.25 / 4.0);
     font.SetGenericFamily(FontDescription::kMonospaceFamily);
