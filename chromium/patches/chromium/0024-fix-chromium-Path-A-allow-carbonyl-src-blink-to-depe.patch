-// The blink/renderer/core includes, the TextCaptureDevice class, and the
-// render_callback_ lambda are all temporarily disabled until #28 (Path A)
-// extracts text capture into a real blink TU. Bitmap rendering is unaffected.
-// See #27 for the full diagnosis.
+// Path A (#28): text capture moved into a dedicated blink TU.
+//
+// Previously this file included a stack of blink/renderer/core/* headers and
+// inlined a TextCaptureDevice/RendererService implementation. That triggered
+// an Oilpan/cppgc cascade in M135 (#27). The implementation now lives in
+// //carbonyl/src/blink:text_capture, a real blink translation unit. We only
+// need its public header here, which is intentionally narrow and pulls in
+// nothing from blink/renderer/*.
+#include "carbonyl/src/blink/text_capture.h"
