From 5895aeef5927311a7abdb2ba028a2ef40282427f Mon Sep 17 00:00:00 2001
From: Carbonyl Maintainers <maintainers@carbonyl.dev>
Date: Fri, 26 Jun 2026 00:00:00 +0000
Subject: [PATCH 34/34] carbonyl: honor file-dialog path in headless picker

Headless select-file dialogs currently cancel immediately. In Carbonyl there is
no GUI picker, so allow operators and automation to provide a deterministic
picker response with --file-dialog-path while preserving the existing cancel
behavior when the switch is absent.

---
 .../select_file_dialog/headless_select_file_dialog.cc     | 31 ++++++++++++++++++++
 1 file changed, 31 insertions(+)

diff --git a/components/headless/select_file_dialog/headless_select_file_dialog.cc b/components/headless/select_file_dialog/headless_select_file_dialog.cc
index 23af76dec60b7..4331e9829fe6b 100644
--- a/components/headless/select_file_dialog/headless_select_file_dialog.cc
+++ b/components/headless/select_file_dialog/headless_select_file_dialog.cc
@@ -4,11 +4,31 @@

 #include "components/headless/select_file_dialog/headless_select_file_dialog.h"

+#include <vector>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
 #include "base/memory/ptr_util.h"
 #include "ui/gfx/native_ui_types.h"
+#include "ui/shell_dialogs/selected_file_info.h"

 namespace headless {

+namespace {
+
+constexpr char kFileDialogPathSwitch[] = "file-dialog-path";
+
+base::FilePath GetConfiguredFileDialogPath() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line || !command_line->HasSwitch(kFileDialogPathSwitch)) {
+    return base::FilePath();
+  }
+  return command_line->GetSwitchValuePath(kFileDialogPathSwitch);
+}
+
+}  // namespace
+
 // static
 HeadlessSelectFileDialogFactory* HeadlessSelectFileDialogFactory::instance_ =
     nullptr;
@@ -48,6 +68,17 @@ class HeadlessSelectFileDialog : public ui::SelectFileDialog {
       std::move(callback_).Run(type);
     }

+    base::FilePath configured_path = GetConfiguredFileDialogPath();
+    if (!configured_path.empty() && listener_) {
+      ui::SelectedFileInfo selected_file(configured_path);
+      if (type == SELECT_OPEN_MULTI_FILE) {
+        listener_->MultiFilesSelected({selected_file});
+      } else {
+        listener_->FileSelected(selected_file, file_type_index);
+      }
+      return;
+    }
+
     if (listener_) {
       listener_->FileSelectionCanceled();
     }
--
