   if (gfx::NativeView native_view =
@@ -63,7 +63,9 @@ void HeadlessPlatformDelegate::SetWebContentsBounds(
   }
 
   // Update RootWindow.
-  web_contents->window_tree_host()->SetBoundsInPixels(bounds);
