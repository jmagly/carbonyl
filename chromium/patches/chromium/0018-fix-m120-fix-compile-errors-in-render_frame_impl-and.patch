From 9490c815aa002be39da7d789a6acac77a4ca1e61 Mon Sep 17 00:00:00 2001
From: Joseph Magly <1159087+jmagly@users.noreply.github.com>
Date: Sat, 4 Apr 2026 21:51:24 -0400
Subject: [PATCH 18/21] fix(m120): fix compile errors in render_frame_impl and
 headless_browser_impl
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- render_frame_impl.h: include carbonyl.mojom.h (full type needed for mojo::Remote<>)
- render_frame_impl.cc: fix SkEncodedImageFormat path (core→codec), replace SkBase64 with base::Base64Decode (src/base not public in M120)
- headless_browser_impl.h: add missing did_shutdown_ member variable
- headless_browser_impl.cc: set did_shutdown_ = true in Shutdown()
---
 content/renderer/render_frame_impl.cc         | 20 +++++--------------
 content/renderer/render_frame_impl.h          |  1 +
 headless/lib/browser/headless_browser_impl.cc |  1 +
 headless/lib/browser/headless_browser_impl.h  |  1 +
 4 files changed, 8 insertions(+), 15 deletions(-)

diff --git a/content/renderer/render_frame_impl.cc b/content/renderer/render_frame_impl.cc
index d9fdbc37751d3..d8f18811a672d 100644
--- a/content/renderer/render_frame_impl.cc
+++ b/content/renderer/render_frame_impl.cc
@@ -281,14 +281,14 @@
 #include "third_party/blink/renderer/core/layout/layout_view.h"
 #include "third_party/blink/renderer/platform/graphics/paint/cull_rect.h"
 #include "third_party/blink/renderer/platform/graphics/paint/paint_record_builder.h"
-#include "third_party/skia/include/core/SkEncodedImageFormat.h"
+#include "third_party/skia/include/codec/SkEncodedImageFormat.h"
 #include "third_party/skia/include/core/SkMesh.h"
 #include "third_party/skia/include/core/SkStream.h"
 #include "third_party/skia/include/core/SkSurface.h"
 #include "third_party/skia/include/core/SkVertices.h"
 #include "third_party/skia/include/docs/SkPDFDocument.h"
 #include "third_party/skia/include/svg/SkSVGCanvas.h"
-#include "third_party/skia/include/utils/SkBase64.h"
+#include "base/base64.h"
 #include "third_party/skia/src/text/GlyphRun.h"
 #include "third_party/skia/src/core/SkClipStackDevice.h"
 #include "third_party/skia/src/core/SkDevice.h"
@@ -2190,25 +2190,15 @@ protected:
 
       base64[runSize] = '\0';
 
-      size_t size = 0;
-      auto error = SkBase64::Decode(base64, runSize, nullptr, &size);
+      auto decoded = base::Base64Decode(std::string_view(base64, runSize));
 
-      if (error != SkBase64::kNoError) {
-          return;
-      }
-
-      auto utf8_ptr = std::make_unique<char[]>(size);
-      char* utf8 = utf8_ptr.get();
-
-      error = SkBase64::Decode(base64, runSize, utf8, &size);
-
-      if (error != SkBase64::kNoError) {
+      if (!decoded) {
           return;
       }
 
       data_.push_back(
         carbonyl::mojom::TextData::New(
-          std::string(utf8, size),
+          std::string(decoded->begin(), decoded->end()),
           gfx::RectF(position.x(), position.y(), 0, 0),
           paint.getColor()
         )
diff --git a/content/renderer/render_frame_impl.h b/content/renderer/render_frame_impl.h
index 92255d5cb15b6..ed7fa455ac50e 100644
--- a/content/renderer/render_frame_impl.h
+++ b/content/renderer/render_frame_impl.h
@@ -124,6 +124,7 @@
 #include "url/gurl.h"
 #include "url/origin.h"
 #include "v8/include/v8-forward.h"
+#include "carbonyl/src/browser/carbonyl.mojom.h"
 
 #if BUILDFLAG(ENABLE_PPAPI)
 #include "content/common/pepper_plugin.mojom.h"
diff --git a/headless/lib/browser/headless_browser_impl.cc b/headless/lib/browser/headless_browser_impl.cc
index 2dfc8cee05b4c..4fd973c4fbed9 100644
--- a/headless/lib/browser/headless_browser_impl.cc
+++ b/headless/lib/browser/headless_browser_impl.cc
@@ -256,6 +256,7 @@ HeadlessBrowserImpl::BrowserMainThread() const {
 void HeadlessBrowserImpl::Shutdown() {
   DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
 
+  did_shutdown_ = true;
   weak_ptr_factory_.InvalidateWeakPtrs();
   // Make sure GetAllBrowserContexts is sane if called after this point.
   auto tmp = std::move(browser_contexts_);
diff --git a/headless/lib/browser/headless_browser_impl.h b/headless/lib/browser/headless_browser_impl.h
index 74bcd5ee177de..893a3e5eac9be 100644
--- a/headless/lib/browser/headless_browser_impl.h
+++ b/headless/lib/browser/headless_browser_impl.h
@@ -149,6 +149,7 @@ class HEADLESS_EXPORT HeadlessBrowserImpl : public HeadlessBrowser {
   std::optional<HeadlessBrowser::Options> options_;
 
   int exit_code_ = 0;
+  bool did_shutdown_ = false;
 
   base::flat_map<std::string, std::unique_ptr<HeadlessBrowserContextImpl>>
       browser_contexts_;
