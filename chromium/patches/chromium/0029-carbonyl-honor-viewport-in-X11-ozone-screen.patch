From 724312b638b6f3b00c6005f2d85232823cf86dba Mon Sep 17 00:00:00 2001
From: Carbonyl Maintainers <carbonyl@integrolabs.net>
Date: Fri, 22 May 2026 14:30:00 +0000
Subject: [PATCH 29/35] carbonyl: honor --viewport in X11 ozone screen
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Fixes the x11 ozone half of roctinam/carbonyl#99 — Gap 1 in the cycle-1
analysis.

Under `--ozone-platform=x11`, Chromium uses `X11ScreenOzone` rather than
the carbonyl-patched `HeadlessScreen`, so the existing #6 + #11 chain
that wires `Renderer::GetSize()` into the screen's display geometry
never executes. `X11ScreenOzone::GetPrimaryDisplay()` returns whatever
`X11DisplayManager` derived from RandR — the host display geometry —
and `--viewport=WxH` is silently dropped on the layout-viewport side.

This patch teaches `X11ScreenOzone::GetPrimaryDisplay()` to consult the
carbonyl renderer when one is registered. When `Renderer::GetCurrent()`
returns non-null (i.e., we're running under the carbonyl Rust shim), we
construct a display from `Renderer::GetSize()` + `Bridge::GetDPI()`,
mirroring the HeadlessScreen::Resize() pattern from patch 0006/0011.
When the renderer is null (Chromium running without carbonyl), the
original `x11_display_manager_->GetPrimaryDisplay()` path is preserved
verbatim — no behavior change for non-carbonyl consumers.

`X11ScreenOzone::GetDisplayForAcceleratedWidget()` falls through to
`GetPrimaryDisplay()` when `widget == kNullAcceleratedWidget` (the
common case for carbonyl, which uses CARBONYL_X_MIRROR rather than
native ozone-x11 toplevels), so a single override of GetPrimaryDisplay
covers the layout-viewport path.

The patch deliberately does NOT touch `GetAllDisplays()` — carbonyl
operates as a single-display embedder, and rewriting the display list
would require also tracking display IDs, scale changes, and the
RandR observer chain. If a future use case needs multi-display
fidelity under x11 ozone, a follow-up patch can extend this.

Refs: roctinam/carbonyl#99
Refs: roctinam/carbonyl#100  (the terminal-render half, merged
                              separately as commit on main)
---
 ui/ozone/platform/x11/BUILD.gn            |  2 ++
 ui/ozone/platform/x11/x11_screen_ozone.cc | 27 +++++++++++++++++++++++
 2 files changed, 29 insertions(+)

diff --git a/ui/ozone/platform/x11/BUILD.gn b/ui/ozone/platform/x11/BUILD.gn
index de7c3330d47d3..9b0214c6db5ed 100644
--- a/ui/ozone/platform/x11/BUILD.gn
+++ b/ui/ozone/platform/x11/BUILD.gn
@@ -50,6 +50,8 @@ source_set("x11") {
   ]
 
   deps = [
+    "//carbonyl/src/browser:bridge",
+    "//carbonyl/src/browser:renderer",
     "//base",
     "//build:chromecast_buildflags",
     "//components/viz/common/resources:shared_image_format",
diff --git a/ui/ozone/platform/x11/x11_screen_ozone.cc b/ui/ozone/platform/x11/x11_screen_ozone.cc
index 1b2420abcc6fa..4c1548b6a624f 100644
--- a/ui/ozone/platform/x11/x11_screen_ozone.cc
+++ b/ui/ozone/platform/x11/x11_screen_ozone.cc
@@ -6,6 +6,9 @@
 
 #include <memory>
 
+#include "carbonyl/src/browser/bridge.h"
+#include "carbonyl/src/browser/renderer.h"
+#include "ui/gfx/geometry/rect_conversions.h"
 #include "base/containers/flat_set.h"
 #include "ui/base/linux/linux_desktop.h"
 #include "ui/base/x/x11_display_util.h"
@@ -123,6 +126,30 @@ const std::vector<display::Display>& X11ScreenOzone::GetAllDisplays() const {
 }
 
 display::Display X11ScreenOzone::GetPrimaryDisplay() const {
+  // Carbonyl issue #99: when a carbonyl renderer is registered, use its
+  // viewport-respecting size for the primary display geometry instead of
+  // the X server's RandR-reported display. This makes `--viewport=WxH`
+  // (and the cells-derived sample window) honored under
+  // `--ozone-platform=x11`, parity with `--ozone-platform=headless`
+  // (which already routes through carbonyl::HeadlessScreen per patch
+  // 0006/0011). The bypass is conditional — when the carbonyl renderer
+  // is not registered (i.e., Chromium is running standalone), the
+  // original x11_display_manager_ path is preserved verbatim.
+  if (auto* renderer = carbonyl::Renderer::GetCurrent()) {
+    auto size = renderer->GetSize();
+    float dpi = carbonyl::Bridge::GetDPI();
+    if (dpi <= 0.0f) {
+      // Bridge::Configure hasn't run yet (early-startup window before
+      // Renderer::Main fires). Fall through to the X11 path; carbonyl
+      // will reconcile on the next screen resize.
+      return x11_display_manager_->GetPrimaryDisplay();
+    }
+    auto bounds = gfx::Rect(0, 0, size.width(), size.height());
+    display::Display carbonyl_display(
+        x11_display_manager_->GetPrimaryDisplay().id());
+    carbonyl_display.SetScaleAndBounds(dpi, gfx::ScaleToEnclosedRect(bounds, dpi));
+    return carbonyl_display;
+  }
   return x11_display_manager_->GetPrimaryDisplay();
 }
 
