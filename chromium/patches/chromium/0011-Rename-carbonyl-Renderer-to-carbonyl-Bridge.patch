From 9d042f26f8bd38aeae2f2456c2639e09e98fbd90 Mon Sep 17 00:00:00 2001
From: Fathy Boundjadj <hey@fathy.fr>
Date: Sun, 12 Feb 2023 01:29:05 +0100
Subject: [PATCH 11/35] Rename carbonyl::Renderer to carbonyl::Bridge

---
 headless/app/headless_shell.cc                          | 5 ++++-
 headless/app/headless_shell_main.cc                     | 2 +-
 headless/lib/browser/headless_browser_impl.cc           | 6 +++---
 headless/lib/browser/headless_platform_delegate_aura.cc | 3 ++-
 headless/lib/browser/headless_screen.cc                 | 2 +-
 headless/lib/browser/headless_web_contents_impl.cc      | 4 ++--
 6 files changed, 13 insertions(+), 9 deletions(-)

diff --git a/headless/app/headless_shell.cc b/headless/app/headless_shell.cc
index 0ccb47741fda5..d9aea70f2e18a 100644
--- a/headless/app/headless_shell.cc
+++ b/headless/app/headless_shell.cc
@@ -14,6 +14,7 @@
 #include "base/compiler_specific.h"
 #include "base/files/file_util.h"
 #include "base/functional/bind.h"
+#include "base/functional/callback.h"
 #include "base/logging.h"
 #include "base/task/thread_pool.h"
 #include "base/version_info/version_info.h"
@@ -94,7 +95,9 @@ void HeadlessShell::OnBrowserStart(HeadlessBrowser* browser) {
   HeadlessBrowserContext::Builder context_builder =
       browser_->CreateBrowserContextBuilder();
 
-  context_builder.SetWindowSize(carbonyl::Renderer::Main()->GetSize());
+  carbonyl::Bridge::GetCurrent()->StartRenderer();
+
+  context_builder.SetWindowSize(carbonyl::Bridge::GetCurrent()->GetSize());
 
   // Create browser context and set it as the default. The default browser
   // context is used by the Target.createTarget() DevTools command when no other
diff --git a/headless/app/headless_shell_main.cc b/headless/app/headless_shell_main.cc
index 203b06489e0e4..e8dc41abba686 100644
--- a/headless/app/headless_shell_main.cc
+++ b/headless/app/headless_shell_main.cc
@@ -17,7 +17,7 @@
 #include "carbonyl/src/browser/bridge.h"
 
 int main(int argc, const char** argv) {
-  carbonyl_shell_main();
+  carbonyl::Bridge::Main();
 
   content::ContentMainParams params(nullptr);
 #if BUILDFLAG(IS_WIN)
diff --git a/headless/lib/browser/headless_browser_impl.cc b/headless/lib/browser/headless_browser_impl.cc
index 6b7624ee792ad..e5cf7898b5bc2 100644
--- a/headless/lib/browser/headless_browser_impl.cc
+++ b/headless/lib/browser/headless_browser_impl.cc
@@ -283,7 +283,7 @@ bool HeadlessBrowserImpl::ShouldStartDevToolsServer() {
 }
 
 void HeadlessBrowserImpl::Resize() {
-  auto size = carbonyl::Renderer::GetSize();
+  auto size = carbonyl::Bridge::GetCurrent()->Resize();
   auto rect = gfx::Rect(0, 0, size.width(), size.height());
 
   for (auto* ctx: GetAllBrowserContexts()) {
@@ -298,7 +298,7 @@ void HeadlessBrowserImpl::Resize() {
     }
   }
 
-  carbonyl::Renderer::Main()->Resize();
+  carbonyl::Bridge::GetCurrent()->Resize();
 }
 
 void HeadlessBrowserImpl::OnShutdownInput() {
@@ -702,7 +702,7 @@ void HeadlessBrowserImpl::PreMainMessageLoopRun() {
       }
     };
 
-    carbonyl::Renderer::Main()->Listen(&delegate);
+    carbonyl::Bridge::GetCurrent()->Listen(&delegate);
   });
 }
 
diff --git a/headless/lib/browser/headless_platform_delegate_aura.cc b/headless/lib/browser/headless_platform_delegate_aura.cc
index a97eda327d532..99a05598dafe2 100644
--- a/headless/lib/browser/headless_platform_delegate_aura.cc
+++ b/headless/lib/browser/headless_platform_delegate_aura.cc
@@ -56,6 +56,7 @@ void HeadlessPlatformDelegate::SetWebContentsBounds(
   // Browser's window bounds should contain all web contents, so that we're sure
   // that we will actually produce visible damage when taking a screenshot.
 
+
   // Update WebContentsViewAura. This also updates RenderWidgetHostViewAura.
   if (gfx::NativeView native_view =
           web_contents->web_contents()->GetNativeView()) {
@@ -65,7 +66,7 @@ void HeadlessPlatformDelegate::SetWebContentsBounds(
   // Update RootWindow.
   HeadlessWindowTreeHost* host = web_contents->window_tree_host();
   host->window()->SetBounds(bounds);
-  host->SetBoundsInPixels(ScaleToEnclosedRect(bounds, carbonyl::Renderer::GetDPI()));
+  host->SetBoundsInPixels(ScaleToEnclosedRect(bounds, carbonyl::Bridge::GetCurrent()->GetDPI()));
 }
 
 ui::Compositor* HeadlessPlatformDelegate::GetCompositor(
diff --git a/headless/lib/browser/headless_screen.cc b/headless/lib/browser/headless_screen.cc
index 8f4586f311f7c..0cd8cdf6bad38 100644
--- a/headless/lib/browser/headless_screen.cc
+++ b/headless/lib/browser/headless_screen.cc
@@ -99,7 +99,7 @@ void HeadlessScreen::CreateDisplayList(const gfx::Size& window_size,
 
   bool is_primary = true;
   base::flat_set<int64_t> internal_display_ids;
-  float dpi = carbonyl::Renderer::GetDPI();
+  float dpi = carbonyl::Bridge::GetCurrent()->GetDPI();
   for (const auto& it : screen_info) {
     Display display(display::HeadlessScreenManager::GetNewDisplayId());
     display.set_label(it.label);
diff --git a/headless/lib/browser/headless_web_contents_impl.cc b/headless/lib/browser/headless_web_contents_impl.cc
index e886771cdaa70..a7e7d10c19077 100644
--- a/headless/lib/browser/headless_web_contents_impl.cc
+++ b/headless/lib/browser/headless_web_contents_impl.cc
@@ -477,7 +477,7 @@ void HeadlessWebContentsImpl::TitleWasSet(content::NavigationEntry* entry) {
   if (!web_contents() || !web_contents()->GetPrimaryMainFrame()->IsActive())
     return;
 
-  carbonyl::Renderer::Main()->SetTitle(base::UTF16ToUTF8(entry->GetTitleForDisplay()));
+  carbonyl::Bridge::GetCurrent()->SetTitle(base::UTF16ToUTF8(entry->GetTitleForDisplay()));
 }
 
 void HeadlessWebContentsImpl::DidFinishNavigation(content::NavigationHandle* handle) {
@@ -488,7 +488,7 @@ void HeadlessWebContentsImpl::DidFinishNavigation(content::NavigationHandle* han
 
   auto& nav = web_contents()->GetController();
 
-  carbonyl::Renderer::Main()->PushNav(
+  carbonyl::Bridge::GetCurrent()->PushNav(
     handle->GetURL().spec(),
     nav.CanGoBack(),
     nav.CanGoForward()
