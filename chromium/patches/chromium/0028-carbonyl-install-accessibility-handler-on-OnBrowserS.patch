From 080815117896e1e72d4b5f47bb82c3b9b57b2b75 Mon Sep 17 00:00:00 2001
From: Carbonyl Maintainers <carbonyl@integrolabs.net>
Date: Fri, 22 May 2026 14:45:00 +0000
Subject: [PATCH 28/35] carbonyl: install accessibility handler on
 OnBrowserStart's WebContents
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Wires `carbonyl::AccessibilityHandler::InstallFor()` into the headless
shell's `OnBrowserStart()`, right after the patch-0027 dump_text
install site.

The handler is a process-wide singleton (carbonyl runs one WebContents
per process in headless mode) that exposes
`carbonyl_get_accessibility_tree()` to the Rust FFI in
`carbonyl/src/browser/bridge.rs`. The Rust side dispatches to it when
the carbonyl-fleet socket layer (roctinam/carbonyl-fleet#10) receives
`{"type": "accessibility_tree"}`.

The handler forces `ui::kAXModeWebContentsOnly` on the BrowserContext
*inside* `InstallFor` (see `accessibility_handler.cc`). This patch
therefore only needs the call-site addition — keeping the chromium-
side surface to a single small hunk that should survive Chromium
rebases without churn. The previous version of this patch attempted
to set the AX mode from `OnBrowserStart` directly, which required
hallucinated include-block context that failed `git am` (build #196
on main, 2026-05-22). Moving the mode-forcing into our owned code
fixes the apply-time corruption.

Refs: roctinam/carbonyl#4
Refs: roctinam/carbonyl-fleet#10
---
 headless/BUILD.gn              |  1 +
 headless/app/headless_shell.cc | 13 +++++++++++++
 2 files changed, 14 insertions(+)

diff --git a/headless/BUILD.gn b/headless/BUILD.gn
index c17c484f15d79..d45bb906bc9ff 100644
--- a/headless/BUILD.gn
+++ b/headless/BUILD.gn
@@ -903,6 +903,7 @@ executable("headless_shell") {
 
   deps = [
     ":headless_shell_lib",
+    "//carbonyl/src/browser:accessibility",
     "//carbonyl/src/browser:dump_text",
     "//carbonyl/src/browser:renderer",
     "//build:branding_buildflags",
diff --git a/headless/app/headless_shell.cc b/headless/app/headless_shell.cc
index 95a5cb6dbf8c7..0bf9cb5cb96df 100644
--- a/headless/app/headless_shell.cc
+++ b/headless/app/headless_shell.cc
@@ -4,6 +4,7 @@
 
 #include "headless/public/headless_shell.h"
 
+#include "carbonyl/src/browser/accessibility_handler.h"
 #include "carbonyl/src/browser/dump_text_handler.h"
 #include "carbonyl/src/browser/renderer.h"
 
@@ -149,6 +150,18 @@ void HeadlessShell::OnBrowserStart(HeadlessBrowser* browser) {
         HeadlessWebContentsImpl::From(web_contents)->web_contents(),
         browser);
   }
+
+  // Carbonyl issue #4: install the accessibility-tree FFI handler on
+  // the freshly built WebContents. Always-on (no CLI gate) because the
+  // FFI surface is process-wide and the carbonyl-fleet socket layer
+  // (#10) decides whether to expose it externally. The handler forces
+  // ui::kAXModeWebContentsOnly on the BrowserContext internally (see
+  // accessibility_handler.cc::InstallFor) so the first FFI snapshot
+  // has populated nodes to walk.
+  if (web_contents) {
+    carbonyl::AccessibilityHandler::InstallFor(
+        HeadlessWebContentsImpl::From(web_contents)->web_contents());
+  }
 }
 
 #if defined(HEADLESS_ENABLE_COMMANDS)
