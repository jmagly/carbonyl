+      event.click_count = 1;
+      event.SetType(blink::WebInputEvent::Type::kMouseDown);
+      event.SetTimeStamp(base::TimeTicks::Now());
+      event.SetPositionInWidget(x, y);
+      event.SetPositionInScreen(x, y);
