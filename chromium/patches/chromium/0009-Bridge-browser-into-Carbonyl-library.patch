+void HeadlessBrowserImpl::OnMouseMoveInput(unsigned int x, unsigned int y) {
+  for (auto* ctx: GetAllBrowserContexts()) {
+    for (auto* contents: ctx->GetAllWebContents()) {
+      auto* impl = HeadlessWebContentsImpl::From(contents);
+
+      if (!impl) {
