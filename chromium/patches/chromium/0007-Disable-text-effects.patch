Subject: [PATCH 07/35] Disable text effects

---
 .../core/paint/text_decoration_painter.cc     | 30 +---------------
 ui/gfx/render_text.cc                         | 36 +++++++++----------
 2 files changed, 19 insertions(+), 47 deletions(-)

diff --git a/third_party/blink/renderer/core/paint/text_decoration_painter.cc b/third_party/blink/renderer/core/paint/text_decoration_painter.cc
index 221ed3d2197e4..94112d362efe7 100644
--- a/third_party/blink/renderer/core/paint/text_decoration_painter.cc
+++ b/third_party/blink/renderer/core/paint/text_decoration_painter.cc
@@ -177,35 +177,7 @@ void TextDecorationPainter::PaintUnderOrOverLineDecorations(
             continue;
           }
 
-          if (decoration.HasUnderline() && decoration.HasFontData() &&
-              EnumHasFlags(lines_to_paint, TextDecorationLine::kUnderline)) {
-            DecorationGeometry geometry =
-                decoration_info.ComputeUnderlineLineData(decoration,
-                                                         decoration_offset);
-            text_painter_.ClipDecorationLine(
-                geometry, decoration_info.BaselineForInkSkip(),
-                fragment_paint_info, skip_ink);
-
-            text_painter_.PaintDecorationLine(
-                geometry, decoration_info.HasDecorationOverride(),
-                LineColorForPhase(decoration_info, decoration, phase),
-                auto_dark_mode);
-          }
-
-          if (decoration.HasOverline() && decoration.HasFontData() &&
-              EnumHasFlags(lines_to_paint, TextDecorationLine::kOverline)) {
-            DecorationGeometry geometry =
-                decoration_info.ComputeOverlineLineData(decoration,
-                                                        decoration_offset);
-            text_painter_.ClipDecorationLine(
-                geometry, decoration_info.BaselineForInkSkip(),
-                fragment_paint_info, skip_ink);
-
-            text_painter_.PaintDecorationLine(
-                geometry, decoration_info.HasDecorationOverride(),
-                LineColorForPhase(decoration_info, decoration, phase),
-                auto_dark_mode);
-          }
+          // carbonyl: underline/overline painting disabled (text effects patch)
         }
       },
       paint_info_.context, text_style);
diff --git a/ui/gfx/render_text.cc b/ui/gfx/render_text.cc
index 7354fcc97fe31..b005a7c21b630 100644
--- a/ui/gfx/render_text.cc
+++ b/ui/gfx/render_text.cc
@@ -56,9 +56,9 @@ constexpr char16_t kEllipsisCodepoint = 0x2026;
 
 // Fraction of the text size to raise the center of a strike-through line above
 // the baseline.
-const SkScalar kStrikeThroughOffset = (SK_Scalar1 * 65 / 252);
+// const SkScalar kStrikeThroughOffset = (SK_Scalar1 * 65 / 252);
 // Fraction of the text size to lower an underline below the baseline.
-const SkScalar kUnderlineOffset = (SK_Scalar1 / 9);
+// const SkScalar kUnderlineOffset = (SK_Scalar1 / 9);
 
 // Float comparison needs epsilon to consider rounding errors in float
 // arithmetic. Epsilon should be dependent on the context and here, we are
@@ -387,28 +387,28 @@ void SkiaTextRenderer::DrawUnderline(int x,
                                      int y,
                                      int width,
                                      SkScalar thickness_factor) {
-  SkScalar x_scalar = SkIntToScalar(x);
-  const SkScalar text_size = font_.getSize();
-  SkRect r = SkRect::MakeLTRB(
-      x_scalar, y + text_size * kUnderlineOffset, x_scalar + width,
-      y + (text_size *
-           (kUnderlineOffset +
-            (thickness_factor * RenderText::kLineThicknessFactor))));
-  canvas_skia_->drawRect(r, flags_);
+  // SkScalar x_scalar = SkIntToScalar(x);
+  // const SkScalar text_size = font_.getSize();
+  // SkRect r = SkRect::MakeLTRB(
+  //     x_scalar, y + text_size * kUnderlineOffset, x_scalar + width,
+  //     y + (text_size *
+  //          (kUnderlineOffset +
+  //           (thickness_factor * RenderText::kLineThicknessFactor))));
+  // canvas_skia_->drawRect(r, flags_);
 }
 
 void SkiaTextRenderer::DrawStrike(int x,
                                   int y,
                                   int width,
                                   SkScalar thickness_factor) {
-  const SkScalar text_size = font_.getSize();
-  // Strike should have a minimum height of 1.0f.
-  const SkScalar height = std::max(1.0f, text_size * thickness_factor);
-  const SkScalar top = y - text_size * kStrikeThroughOffset - height / 2;
-  SkScalar x_scalar = SkIntToScalar(x);
-  const SkRect r =
-      SkRect::MakeLTRB(x_scalar, top, x_scalar + width, top + height);
-  canvas_skia_->drawRect(r, flags_);
+  // const SkScalar text_size = font_.getSize();
+  // // Strike should have a minimum height of 1.0f.
+  // const SkScalar height = std::max(1.0f, text_size * thickness_factor);
+  // const SkScalar top = y - text_size * kStrikeThroughOffset - height / 2;
+  // SkScalar x_scalar = SkIntToScalar(x);
+  // const SkRect r =
+  //     SkRect::MakeLTRB(x_scalar, top, x_scalar + width, top + height);
+  // canvas_skia_->drawRect(r, flags_);
 }
 
