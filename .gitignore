.venv

# Python
__pycache__/
*.pyc
*.pyo

/.ccache
/.git_cache
/.vscode
/build/*
# Build-environment + image Dockerfiles are source, not build output.
!/build/Dockerfile.builder
!/build/Dockerfile.runtime
!/build/docker-entrypoint.sh
/chromium/*
!/chromium/.gclient
!/chromium/depot_tools
!/chromium/patches
/packages/*/build

# AIWG runtime artifacts (working files, agent-loop state)
.aiwg/working/
.aiwg/ralph/
.aiwg/ralph-external/
.aiwg/security-engineering/reviews/disclosures/

# Agentic provider conventional dirs (generated by aiwg use, not authored)
.cursor/agents/
.cursor/commands/
.cursor/skills/
.factory/skills/
.factory/rules/
.warp/
.windsurf/agents/
.windsurf/skills/
.windsurf/rules/
